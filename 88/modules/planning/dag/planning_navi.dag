# Define all coms in DAG streaming.
module_config {
  module_library : "/century/bazel-bin/modules/planning/libplanning_component.so"
  timer_components {
    class_name : "PlanningComponent"
    config {
      name: "planning"
      config_file_path:  "/century/modules/planning/conf/planning_config_navi.pb.txt"
      flag_file_path:  "/century/modules/planning/conf/planning_navi.conf"
      interval: 100
    }
  }
}
