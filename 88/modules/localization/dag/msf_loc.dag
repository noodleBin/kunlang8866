# Define all coms in DAG streaming.
module_config {
    module_library : "/century/bazel-bin/modules/localization/msf/libmsf_loc_component.so"

    components {
      class_name : "MsfLocComponent"
      config {
        name : "msf_loc"
        #flag_file_path : "/century/modules/localization/conf/loc.conf"
        config_file_path : "/century/modules/localization/conf/msf_config.pb.txt"
        readers: [
          {
            channel: "/century/sensor/gnss/corrected_imu"
            qos_profile: {
              depth : 10
            }
            pending_queue_size: 50
          }
        ]
      }
    }
}