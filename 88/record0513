#!/bin/bash
# set -x
cd /century/data/bag/
current_date=$(date +"%Y%m%d")
# seven_days_ago=$(date -d "7 days ago" +"%Y%m%d")

# for dir in $(ls -d */ | grep -E "^[0-9]{8}/$" | sed 's#/##'); do
#     if [[ "$dir" < "$seven_days_ago" ]]; then
#         echo "delete dir: $dir"
#         rm -r "$dir"
#     fi
