module_config {
    module_library : "/century/bazel-bin/modules/control/libcontrol_component.so"

    timer_components {
        class_name : "ControlComponent"
        config {
            name: "control"
            flag_file_path: "/century/modules/control/conf/control.conf"
            interval: 10
      }
    }

    components {
        class_name : "PreprocessorSubmodule"
        config {
            name: "PreprocessorSubmodule"
            config_file_path: "/century/modules/control/conf/control_common_conf.pb.txt"
            flag_file_path: "/century/modules/control/conf/control.conf"
            readers: [
                {
                    channel:"/century/control/localview"
                }
            ]
        }
    }

    components {
        class_name : "MPCControllerSubmodule"
        config {
            name: "MPCControllerSubmodule"
            flag_file_path: "/century/modules/control/conf/control.conf"
            readers: [
                {
                    channel:"/century/control/preprocessor"
                }
            ]
        }
    }

    components {
        class_name : "PostprocessorSubmodule"
        config {
            name: "PostprocessorSubmodule"
            config_file_path: "/century/modules/control/conf/control_common_conf.pb.txt"
            flag_file_path: "/century/modules/control/conf/control.conf"
            readers: [
                {
                    channel:"/century/control/controlcore"
                }
            ]
        }
    }
}
