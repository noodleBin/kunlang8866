module_config {
  module_library : "/century/bazel-bin/modules/perception/onboard/component/libperception_component_lidar.so"

#  components {
#    class_name : "DetectionComponent"
#    config {
#      name: "Velodyne128Detection"
#      config_file_path: "/century/modules/perception/production/conf/perception/lidar/velodyne128_detection_conf.pb.txt"
#      flag_file_path: "/century/modules/perception/production/conf/perception/perception_common.flag"
#      readers {
#        channel: "/century/ros2_lidar_left"
#      }
#    }
#  }

  components {
    class_name : "DetectionComponent"
    config {
      name: "HeliosBp32Detection"
      config_file_path: "/century/modules/perception/production/conf/perception/lidar/helios_front_left_conf.pb.txt"
      flag_file_path: "/century/modules/perception/production/conf/perception/perception_common.flag"
      readers {
        channel: "/century/ros2_lidar_left"
      }
    }
  }

  components {
    class_name : "RecognitionComponent"
    config {
      name: "RecognitionComponent"
      config_file_path: "/century/modules/perception/production/conf/perception/lidar/recognition_conf.pb.txt"
      readers {
        channel: "/perception/inner/DetectionObjects"
      }
    }
  }

  components {
    class_name: "FusionComponent"
    config {
      name: "SensorFusion"
      config_file_path: "/century/modules/perception/production/conf/perception/fusion/fusion_component_conf.pb.txt"
      readers {
        channel: "/perception/inner/PrefusedObjects"
      }
    }
  }
}

module_config {
  module_library : "/century/bazel-bin/modules/v2x/fusion/apps/libv2x_fusion_component.so"

  components {
    class_name : "V2XFusionComponent"
    config {
      name : "v2x_fusion"
      flag_file_path : "/century/modules/v2x/conf/v2x_fusion_tracker.conf"
      readers: [
        {
          channel: "/perception/vehicle/obstacles"
        }
      ]
    }
  }
}