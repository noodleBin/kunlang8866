module_config {
    module_library : "/century/bazel-bin/modules/prediction/submodules/prediction_lego.so"

    components {
        class_name : "PredictionComponent"
        config {
            name: "prediction"
            config_file_path: "/century/modules/prediction/conf/prediction_conf.pb.txt"
            flag_file_path: "/century/modules/prediction/conf/prediction.conf"
            readers: [
                {
                    channel: "/century/perception/obstacles"
                    qos_profile: {
                        depth : 1
                    }
                }
            ]
        }
    }

    components {
        class_name : "EvaluatorSubmodule"
        config {
            name: "evaluator_submodule"
            config_file_path: "/century/modules/prediction/conf/prediction_conf.pb.txt"
            flag_file_path: "/century/modules/prediction/conf/prediction.conf"
            readers: [
                {
                    channel:"/century/prediction/container"
                    qos_profile: {
                        depth : 1
                    }
                }
            ]
        }
    }

    components {
        class_name : "PredictorSubmodule"
        config {
            name: "predictor submodule"
            config_file_path: "/century/modules/prediction/conf/prediction_conf.pb.txt"
            flag_file_path: "/century/modules/prediction/conf/prediction.conf"
            readers: [
                {
                    channel: "/century/prediction/perception_obstacles"
                    qos_profile: {
                        depth : 1
                    }
                },
                {
                    channel:"/century/prediction/adccontainer"
                    qos_profile: {
                        depth : 1
                    }
                },
                {
                    channel:"/century/prediction/evaluator"
                    qos_profile: {
                        depth : 1
                    }
                }
            ]
        }
    }
}
