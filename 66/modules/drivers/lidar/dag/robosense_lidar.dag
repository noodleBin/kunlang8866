# Define all coms in DAG streaming.

module_config {                                             
  module_library : "/century/bazel-bin/modules/drivers/lidar/liblidar_driver_component.so"
  components {
    class_name : "LidarDriverComponent"
    config {
      name : "lidar_driver"
      config_file_path : "/century/modules/drivers/lidar/conf/lidar_config.pb.txt"
      readers {channel: "/century/sensor/lidar/driver"}
    }
  }
}
module_config {
    module_library : "/century/bazel-bin/modules/drivers/lidar/velodyne/compensator/libvelodyne_compensator_component.so"
    components {
      class_name : "CompensatorComponent"
      config {
        name : "RS16_Compensator"
        config_file_path : "/century/modules/drivers/lidar/robosense/conf/rs16_compensator.pb.txt"
        readers {channel: "/century/sensor/rs16/PointCloud2"}
      }
    }
}

